{
  "name": "chat-gpt-clone",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:prod": "ng build --configuration=production",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:ci": "ng test --watch=false --browsers=ChromeHeadless",
    "test:watch": "ng test --watch",
    "test:coverage": "ng test --code-coverage --watch=false --browsers=ChromeHeadless",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "e2e:ci": "playwright test --reporter=line",
    "lint": "ng lint",
    "lint:fix": "ng lint --fix",
    "format": "prettier --write \"src/**/*.{ts,html,css,scss,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,css,scss,json}\"",
    "analyze:bundle": "ng build --configuration=production --stats-json && npx webpack-bundle-analyzer dist/chat-gpt-clone/browser/stats.json",
    "analyze:source-map": "ng build --configuration=production --source-map && npx source-map-explorer dist/chat-gpt-clone/browser/*.js",
    "lighthouse": "ng build --configuration=production && npx lighthouse http://localhost:4200 --output=json --output=html --output-path=./lighthouse-report",
    "lighthouse:ci": "ng build --configuration=production && npx @lhci/cli autorun",
    "test:performance": "ng build --configuration=production && node scripts/performance-test.js",
    "ci": "npm run lint && npm run test:ci && npm run build:prod",
    "precommit": "npm run format:check && npm run lint && npm run test:ci"
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^20.2.0",
    "@angular/compiler": "^20.2.0",
    "@angular/core": "^20.2.0",
    "@angular/fire": "^20.0.1",
    "@angular/forms": "^20.2.0",
    "@angular/platform-browser": "^20.2.0",
    "@angular/platform-browser-dynamic": "^20.2.0",
    "@angular/router": "^20.2.0",
    "@fortawesome/fontawesome-free": "^6.7.2",
    "@google/genai": "^1.20.0",
    "firebase": "^12.2.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^20.2.2",
    "@angular/cli": "^20.2.2",
    "@angular/compiler-cli": "^20.2.0",
    "@playwright/test": "^1.55.1",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^24.5.2",
    "angular-eslint": "20.2.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.33.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "glob": "^11.0.3",
    "jasmine-core": "~5.9.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.40.0",
    "zone.js": "^0.15.1"
  }
}
